## Judge provider: "anthropic" (default) or "openai"
JUDGE_PROVIDER=anthropic

## Anthropic config (used when JUDGE_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_key_here
JUDGE_MODEL=claude-sonnet-4-6

## OpenAI config (used when JUDGE_PROVIDER=openai)
# OPENAI_API_KEY=your_key_here
# JUDGE_MODEL=gpt-4o

JUDGE_PASS_THRESHOLD=0.6
GEMINI_CLI_ACTIVITY_LOG_TARGET=/tmp/gemini_activity.jsonl
